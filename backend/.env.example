# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/launchpad"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Solana RPC ────────────────────────────────────────────────────────────────
# Get a free key at https://helius.dev
RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"
RPC_URL_DEVNET="https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY"

# ── Helius Webhooks ───────────────────────────────────────────────────────────
# Set this in the Helius dashboard and copy it here
HELIUS_WEBHOOK_SECRET="your_webhook_secret"

# ── Program ───────────────────────────────────────────────────────────────────
# Set this after `anchor deploy` on devnet
PROGRAM_ID="Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS"

# ── Business Logic ────────────────────────────────────────────────────────────
# Whale alert threshold in SOL — trades above this trigger isWhale=true
WHALE_THRESHOLD_SOL="10"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="4000"
WS_PORT="4001"
NODE_ENV="development"

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────
# Get keys at https://pinata.cloud
PINATA_API_KEY="your_pinata_api_key"
PINATA_SECRET_API_KEY="your_pinata_secret"
PINATA_GATEWAY="https://gateway.pinata.cloud"
