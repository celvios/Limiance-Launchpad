  "types": [
    {
      "name": "BuyEvent",
      "docs": [
        "Emitted after every successful buy."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "mint",
            "docs": [
              "SPL Mint purchased."
            ],
            "type": "pubkey"
          },
